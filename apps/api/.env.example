# ---- Application ----
APP_NAME=TranscribeOP
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=4000
APP_DEBUG=true
APP_VERSION=1.0.0

# ---- Security ----
# Generate a strong secret, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`
JWT_SECRET_KEY=replace-with-a-strong-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Portal credential (single-account portal) ----
# The portal is locked to ONE provisioned account. Set these in your secret
# store (or local .env for dev). On startup the API seeds/updates this user
# in the database; any other accounts are removed.
PORTAL_USER_EMAIL=user@example.com
PORTAL_USER_PASSWORD=replace-with-a-strong-password
PORTAL_USER_NAME=Portal User

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Database (SQLite for dev, switch to PostgreSQL for prod) ----
DATABASE_URL=sqlite+aiosqlite:///./transcribeop.db
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ---- Storage (local | azure_blob) ----
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=transcribeop

# ---- Queue (background | celery) ----
QUEUE_BACKEND=background
REDIS_URL=redis://localhost:6379/0

# ---- Azure OpenAI ----
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-5-sop
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_MAX_TOKENS=4096
AZURE_OPENAI_TEMPERATURE=0.2
AZURE_OPENAI_TIMEOUT_SECONDS=120

# ---- Rate limiting ----
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AI=20/minute
RATE_LIMIT_UPLOAD=30/minute

# ---- File upload ----
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_EXTENSIONS=pdf,docx,txt,md

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json
